# ============================================================================
# BLOCKMINER - Environment Configuration
# ============================================================================
# Copy this file to .env and fill in the values below.
# NEVER commit .env to version control (it's in .gitignore)
# ============================================================================

# ============================================================================
# SECURITY (REQUIRED)
# ============================================================================

# JWT Secret for authentication tokens
# REQUIRED: Must be at least 32 characters (use: openssl rand -hex 64)
# If not set, the server will refuse to start
JWT_SECRET=

# JWT Token TTL (Time To Live)
ACCESS_TOKEN_TTL=12h
REFRESH_TOKEN_TTL_DAYS=30
JWT_ISSUER=blockminer
JWT_AUDIENCE=blockminer.app

# ============================================================================
# CORS & DEPLOYMENT
# ============================================================================

# Allowed origins for CORS (comma-separated)
# Production example: https://blockminer.space,https://www.blockminer.space
# Leave empty to allow localhost-only (development)
CORS_ORIGINS=

# Node environment
NODE_ENV=production
PORT=3000

# ============================================================================
# STARTUP SAFETY (RECOMMENDED: keep false in production)
# ============================================================================

# If true, container startup runs:
# - prisma db push
# - node server/prisma/seed.js
# Keep FALSE in production unless you explicitly want schema/data bootstrap.
DB_BOOTSTRAP_ON_STARTUP=false

# If true, server startup runs one-time data migration scripts (shortlinks/powers/etc).
# Keep FALSE in production unless explicitly planned.
RUN_STARTUP_DATA_MIGRATIONS=false

# App URL (for OAuth callbacks, email links, etc)
# Production: https://blockminer.space
# Development: http://localhost:3000
APP_URL=https://blockminer.space

# Logging level (case-insensitive): ERROR, WARN, INFO, DEBUG
LOG_LEVEL=INFO

# ============================================================================
# ADMIN USERS (REQUIRED for production)
# ============================================================================

# Comma-separated list of admin email addresses (legacy)
# Example: admin@example.com,super-admin@example.com
# In development (NODE_ENV != production) with empty list, all authenticated users can access admin
ADMIN_EMAILS=admin@example.com

# Admin login credentials
# Email for admin login
ADMIN_EMAIL=admin@blockminer.com

# Security code for admin login (minimum 4 characters)
# IMPORTANT: Keep this secure and do not commit to version control
ADMIN_SECURITY_CODE=CHANGE_ME_STRONG_UNIQUE_CODE

# Admin session cookie: Secure flag (optional). false = allow HTTP (e.g. direct IP:port).
# Omit = Secure only when the request is HTTPS (or X-Forwarded-Proto: https).
# ADMIN_SESSION_COOKIE_SECURE=false

# JWT expiration time for admin sessions
ADMIN_JWT_EXPIRES_IN=24h

# ============================================================================
# DATABASE
# ============================================================================

# SQLite database path (inside Docker at /app/data/blockminer.db)
# Leave empty to use default; will be set in docker-compose.yml
DB_PATH=/app/data/blockminer.db

# ============================================================================
# FAUCET (Postgres / Prisma — valores só na criação do miner; depois persistem no DB)
# ============================================================================
# Slug do registro em miners (padrão: faucet-micro-miner)
# FAUCET_MINER_SLUG=faucet-micro-miner
# FAUCET_MINER_NAME=Pulse Mini v1
# FAUCET_POWER=1
# FAUCET_BASE_HASH_RATE=1
# FAUCET_IMAGE_URL=/machines/reward2.png
# FAUCET_COOLDOWN_MS=3600000

# ============================================================================
# BACKUP (local + external)
# ============================================================================

# Enable/disable backup cron
BACKUP_ENABLED=true

# Daily backup schedule (03:00 server time)
BACKUP_CRON=0 3 * * *

# Run one backup on startup
BACKUP_RUN_ON_STARTUP=true
BACKUP_STARTUP_DELAY_MS=60000

# Local backup settings
BACKUP_DIR=/app/backups
BACKUP_RETENTION_DAYS=7
BACKUP_FILENAME_PREFIX=blockminer-db-

# External backup replication (optional)
# Example Windows path: D:\\blockminer-external-backups
# Example network path: \\NAS\\blockminer\\backups
BACKUP_EXTERNAL_ENABLED=false
BACKUP_EXTERNAL_DIR=
BACKUP_EXTERNAL_RETENTION_DAYS=30

# Cloud backup command (optional, e.g. Google Drive via rclone)
# Requires rclone configured previously (example remote: gdrive)
# Placeholders available: {backupFile} and {backupFilename}
BACKUP_CLOUD_ENABLED=false
BACKUP_CLOUD_COMMAND=rclone copy "{backupFile}" "gdrive:blockminer-backups" --transfers 1 --checkers 1 --drive-chunk-size 32M --fast-list
BACKUP_CLOUD_TIMEOUT_MS=120000

# Full site backup on startup (includes DB + all source files as tar.gz)
# Automatically uploaded to cloud if BACKUP_CLOUD_ENABLED=true
BACKUP_FULL_SITE_ON_STARTUP=true
BACKUP_FULL_SITE_STARTUP_DELAY_MS=15000

# ============================================================================
# BLOCKCHAIN (Polygon Mainnet)
# ============================================================================

# RPC URL for Polygon (mainnet)
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# RPC timeout (ms) for on-chain reads (failover will try next endpoint)
POLYGON_RPC_TIMEOUT_MS=4500

# Chain ID for Polygon mainnet
POLYGON_CHAIN_ID=137

# Etherscan API key (https://etherscan.io/apidashboard) — used by the deposit scanner (Polygon via v2 API).
# Optional alias: POLYGONSCAN_API_KEY (same value).
ETHERSCAN_API_KEY=

# Optional: dedicated JSON-RPC for check-in verification (e.g. Aether / Alchemy / Infura).
# If unset, POLYGON_RPC_URL is used.
# AETHER_RPC_URL=https://...

# Only needed if you run checkins via smart contract.
DEPOSIT_WALLET_ADDRESS=0xYourDepositAddressHereForPolygon

# Check-in: if CHECKIN_RECEIVER is empty (or 0x0), check-in is FREE (one tap per day, stored in DB).
# If set to a valid address, the legacy on-chain POL payment flow is enabled (Polygon).
CHECKIN_RECEIVER=

# Amount (in Wei) to send per check-in
# Default: 10000000000000000 = 0.01 tokens
CHECKIN_AMOUNT_WEI=10000000000000000

# ============================================================================
# HOT WALLET (for withdrawals & transactions)
# ============================================================================

# Private key of the hot wallet (64 hex chars, no 0x prefix required)
# WARNING: This key will be used to sign transactions! Keep it secure.
WITHDRAWAL_PRIVATE_KEY=

# OR use mnemonic phrase (12-24 words, space-separated)
# If both are set, PRIVATE_KEY takes precedence
WITHDRAWAL_MNEMONIC=

# If true/1, cron sends on-chain POL for withdrawals already **approved** by admin (every 2 min).
# Default (unset/false): manual only — admin copies destination, sends from hot wallet, marks complete with txHash.
WITHDRAWAL_AUTO_SEND=false

# ============================================================================
# CCPAYMENT (CRYPTO DEPOSITS - POLYGON ONLY)
# ============================================================================

# Enable/disable CCPayment integration
CCPAYMENT_ENABLED=false

# API credentials (never commit real values)
CCPAYMENT_APP_ID=
CCPAYMENT_APP_SECRET=

# API endpoints/config (see docs/CCPAYMENT.md — official docs use admin.ccpayment.com/v1 for address API)
CCPAYMENT_API_BASE_URL=https://admin.ccpayment.com/ccpayment/v1
CCPAYMENT_PAYMENT_ADDRESS_PATH=/payment/address/get
CCPAYMENT_TIMEOUT_MS=15000
CCPAYMENT_WEBHOOK_URL=https://your-domain.com/api/wallet/ccpayment/deposit-webhook
# CCPAYMENT_NOTIFY_URL=  (optional; defaults to CCPAYMENT_WEBHOOK_URL)

# Webhook IP allowlist: extra IPs merged with CCPayment AWS egress (see docs)
# CCPAYMENT_ALLOWED_IPS=
CCPAYMENT_MIN_DEPOSIT_POL=0.01

# Deposit acceptance restrictions (webhook body chain/crypto)
CCPAYMENT_CHAIN=POLYGON
CCPAYMENT_ALLOWED_CHAINS=Polygon,MATIC,polygon
CCPAYMENT_ALLOWED_CRYPTOS=POL,MATIC,WPOL

# Behind reverse proxy (webhook client IP)
# TRUST_PROXY=1

# ============================================================================
# APP CONFIG
# ============================================================================

# Date when the app came online (YYYY-MM-DD format)
ONLINE_START_DATE=2026-02-13

# Reward (in GH/s) given for completing memory game
MEMORY_GAME_REWARD_GH=5

# ============================================================================
# ZERADS PTC/OFFERWALL
# ============================================================================

# ZerAds Site ID
ZERADS_SITE_ID=10776

# ZerAds callback password (must match ZerAds dashboard)
# REQUIRED: Generate a strong random password. Example: openssl rand -hex 32
ZERADS_CALLBACK_PASSWORD=

# ZerAds callback source IP whitelist (comma-separated)
# Leave empty to disable IP restriction
ZERADS_ALLOWED_IPS=

# Reward exchange: 1 ZER = X credits/coins on your site
# Set to 0 to disable exchange message and payouts
ZERADS_PTC_EXCHANGE_RATE=0

# Optional reward name displayed to user (coins, credits, usd...)
ZERADS_REWARD_NAME=

# Offerwall URL template
ZERADS_OFFERWALL_URL_TEMPLATE=https://zerads.com/?ref={siteId}&user={username}

# ============================================================================
# FRONTEND (Vite) — Docker build only
# ============================================================================
# Injected when running `docker compose build` (same folder as docker-compose.yml).
# Add these keys to a `.env` file next to docker-compose.yml, or export them before build.
# Local dev: use client/.env (see client/.env.example).

VITE_DISCORD_URL=
VITE_TELEGRAM_URL=

