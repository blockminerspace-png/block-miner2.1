# Copia para deploy.secrets.local (na raiz do repo) e preenche.
# deploy.secrets.local está no .gitignore — NUNCA commites.

SSH_HOST=89.167.119.164
SSH_USER=root
SSH_PASSWORD=your_ssh_password_here
REMOTE_PATH=/root/block-miner

# Opcional: quando o PuTTY diz "host key does not match", cola a linha "SHA256:..." que o plink mostra:
# SSH_HOSTKEY=SHA256:...

# Opcional: após git pull, copia certificados Let's Encrypt já emitidos na VM para nginx/certs
# (evita ERR_CERT_AUTHORITY_INVALID quando o reset traz PEM de desenvolvimento fora do repo).
# LE_SYNC_DOMAIN=tests.blockminer.space

# Deploy: por defeito NÃO envia .env.production se o teu .env.production.vm-backup não tiver
# CCPAYMENT_APP_ID preenchido (evita apagar CCPayment na VPS a cada deploy).
# Força envio mesmo assim: DEPLOY_UPLOAD_ENV_DESPITE_MISSING_CCPAYMENT=1
# Nunca enviar .env: DEPLOY_SKIP_ENV_UPLOAD=1

# Após o contentor subir: aplica migrações Prisma na base (check-in marcos, etc.). Usa 1 na primeira vez ou quando houver migrações novas.
# DEPLOY_PRISMA_MIGRATE_DEPLOY=1
# Se uma migração falhou (P3018) e corrigiste o SQL / base, marca como rolled-back uma vez e volta a correr deploy:
# DEPLOY_PRISMA_MIGRATE_RESOLVE_ROLLED_BACK=20260410000000_add_user_rooms_and_racks
