// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            Int       @id @default(autoincrement())
  name          String
  username      String?   @unique
  email         String    @unique
  passwordHash  String    @map("password_hash")
  createdAt     DateTime  @default(now()) @map("created_at")
  lastLoginAt   DateTime? @map("last_login_at")
  ip            String?
  userAgent     String?   @map("user_agent")
  isBanned      Boolean   @default(false) @map("is_banned")
  refCode       String?   @unique @map("ref_code")
  referredBy    Int?      @map("referred_by")
  walletAddress String?   @map("wallet_address")

  // Balances
  polBalance  Decimal @default(0) @map("pol_balance") @db.Decimal(20, 8)
  btcBalance  Decimal @default(0) @map("btc_balance") @db.Decimal(20, 8)
  ethBalance  Decimal @default(0) @map("eth_balance") @db.Decimal(20, 8)
  usdtBalance Decimal @default(0) @map("usdt_balance") @db.Decimal(20, 8)
  usdcBalance Decimal @default(0) @map("usdc_balance") @db.Decimal(20, 8)
  zerBalance  Decimal @default(0) @map("zer_balance") @db.Decimal(20, 8)

  // Session Tracking
  ytSecondsBalance         Int       @default(0) @map("yt_seconds_balance")
  autoMiningSecondsBalance Int       @default(0) @map("auto_mining_seconds_balance")
  lastHeartbeatAt          DateTime? @map("last_heartbeat_at")

  // Relationships
  miners                  UserMiner[]
  inventory               UserInventory[]
  transactions            Transaction[]
  payouts                 Payout[]
  auditLogs               AuditLog[]
  sessions                Session[]
  refreshTokens           RefreshToken[]
  checkins                DailyCheckin[]
  faucetClaims            FaucetClaim?
  faucetVisits            FaucetPartnerVisit[]
  gamePowers              UserPowerGame[]
  ytPowers                YoutubeWatchPower[]
  ytHistory               YoutubeWatchHistory[]
  rackConfigs             RackConfig[]
  ptpAds                  PtpAd[]
  ptpEarnings             PtpEarning[]
  chatMessages            ChatMessage[]
  sentPrivateMessages     PrivateMessage[]      @relation("SentPrivateMessages")
  receivedPrivateMessages PrivateMessage[]      @relation("ReceivedPrivateMessages")
  gpuAccess               AutoMiningGpu[]
  gpuLogs                 AutoMiningGpuLog[]
  referrals               Referral[]            @relation("UserToReferrer")
  referred                Referral[]            @relation("UserToReferred")
  earnings                ReferralEarning[]     @relation("UserToReferrerEarnings")
  referredEarnings        ReferralEarning[]     @relation("UserToReferredEarnings")
  miningLogs              MiningRewardsLog[]
  shortlinkComp           ShortlinkCompletion?
  hasAdblock              Boolean               @default(false) @map("has_adblock")
  // Migration Meta & Historical Data
  oldId                   Int?                  @unique @map("old_id")
  oldLifetimeMined        Decimal?              @default(0) @map("old_lifetime_mined") @db.Decimal(20, 8)
  totalWithdrawn          Decimal?              @default(0) @map("total_withdrawn") @db.Decimal(20, 8)
  rigsCount               Int?                  @default(0) @map("rigs_count")
  baseHashRate            Float?                @default(0) @map("old_base_hash_rate")

  blockMinerRewards BlockMinerReward[]
  notifications     Notification[]

  @@map("users")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  title     String
  message   String
  type      String   @default("info") // info, success, warning, reward
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model Session {
  token     String   @id
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model RefreshToken {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  tokenId    String    @unique @map("token_id")
  tokenHash  String    @map("token_hash")
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  replacedBy String?   @map("replaced_by")
  user       User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Miner {
  id           Int      @id @default(autoincrement())
  name         String
  slug         String   @unique
  baseHashRate Float    @default(0) @map("base_hash_rate")
  price        Float    @default(0.5)
  slotSize     Int      @default(1) @map("slot_size")
  imageUrl     String?  @map("image_url")
  isActive     Boolean  @default(true) @map("is_active")
  showInShop   Boolean  @default(true) @map("show_in_shop")
  createdAt    DateTime @default(now()) @map("created_at")

  userMiners    UserMiner[]
  userInventory UserInventory[]
  faucetReward  FaucetReward?
  shortlinkRew  ShortlinkReward?

  @@map("miners")
}

model UserMiner {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  minerId     Int?     @map("miner_id")
  slotIndex   Int      @map("slot_index")
  level       Int      @default(1)
  hashRate    Float    @default(0) @map("hash_rate")
  slotSize    Int      @default(1) @map("slot_size")
  imageUrl    String?  @map("image_url")
  isActive    Boolean  @default(true) @map("is_active")
  purchasedAt DateTime @default(now()) @map("purchased_at")

  user  User   @relation(fields: [userId], references: [id])
  miner Miner? @relation(fields: [minerId], references: [id])

  @@unique([userId, slotIndex])
  @@index([userId])
  @@map("user_miners")
}

model UserInventory {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  minerId    Int?     @map("miner_id")
  minerName  String   @map("miner_name")
  level      Int      @default(1)
  hashRate   Float    @default(0) @map("hash_rate")
  slotSize   Int      @default(1) @map("slot_size")
  imageUrl   String?  @map("image_url")
  acquiredAt DateTime @default(now()) @map("acquired_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user  User   @relation(fields: [userId], references: [id])
  miner Miner? @relation(fields: [minerId], references: [id])

  @@index([userId])
  @@map("user_inventory")
}

model Transaction {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  type          String // deposit, withdrawal, etc
  amount        Decimal   @db.Decimal(20, 8)
  address       String?
  txHash        String?   @map("tx_hash")
  rawTx         String?   @map("raw_tx")
  txNonce       Int?      @map("tx_nonce")
  txGasPrice    String?   @map("tx_gas_price")
  txGasLimit    Int?      @map("tx_gas_limit")
  fromAddress   String?   @map("from_address")
  status        String    @default("pending")
  fundsReserved Boolean   @default(false) @map("funds_reserved")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime? @updatedAt @map("updated_at")
  completedAt   DateTime? @map("completed_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([txHash])
  @@map("transactions")
}

model Payout {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  amountPol Float    @map("amount_pol")
  source    String
  txHash    String?  @map("tx_hash")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("payouts")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int?     @map("user_id")
  action      String
  ip          String?
  userAgent   String?  @map("user_agent")
  detailsJson String?  @map("details_json")
  createdAt   DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("audit_logs")
}

model RackConfig {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  rackIndex  Int      @map("rack_index")
  customName String   @map("custom_name")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, rackIndex])
  @@map("rack_configs")
}

model FaucetReward {
  id         Int      @id @default(autoincrement())
  minerId    Int      @unique @map("miner_id")
  cooldownMs Int      @default(3600000) @map("cooldown_ms")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  miner Miner @relation(fields: [minerId], references: [id])

  @@map("faucet_rewards")
}

model FaucetClaim {
  userId      Int      @id @map("user_id")
  claimedAt   DateTime @map("claimed_at")
  totalClaims Int      @default(0) @map("total_claims")
  dayKey      String?  @map("day_key")

  user User @relation(fields: [userId], references: [id])

  @@map("faucet_claims")
}

model FaucetPartnerVisit {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  dayKey     String   @map("day_key")
  openedAt   DateTime @map("opened_at")
  eligibleAt DateTime @map("eligible_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, dayKey])
  @@index([eligibleAt])
  @@map("faucet_partner_visits")
}

model DailyCheckin {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  checkinDate String    @map("checkin_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  confirmedAt DateTime? @map("confirmed_at")
  txHash      String    @unique @map("tx_hash")
  status      String    @default("pending")
  amount      Float     @default(0.01)
  chainId     Int       @map("chain_id")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, checkinDate])
  @@map("daily_checkins")
}

model UserPowerGame {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  gameId    Int      @map("game_id")
  hashRate  Float    @map("hash_rate")
  playedAt  DateTime @map("played_at")
  expiresAt DateTime @map("expires_at")
  checkinId Int?     @map("checkin_id")

  user User @relation(fields: [userId], references: [id])
  game Game @relation(fields: [gameId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("users_powers_games")
}

model Game {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  powers UserPowerGame[]

  @@map("games")
}

model YoutubeWatchPower {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  hashRate      Float    @map("hash_rate")
  claimedAt     DateTime @map("claimed_at")
  expiresAt     DateTime @map("expires_at")
  sourceVideoId String?  @map("source_video_id")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
  @@map("youtube_watch_user_powers")
}

model YoutubeWatchHistory {
  id            Int      @id @default(autoincrement())
  userId        Int      @map("user_id")
  hashRate      Float    @map("hash_rate")
  claimedAt     DateTime @map("claimed_at")
  expiresAt     DateTime @map("expires_at")
  sourceVideoId String?  @map("source_video_id")
  status        String   @default("granted")
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("youtube_watch_power_history")
}

model PtpAd {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  title       String
  url         String
  hash        String   @unique
  createdAt   DateTime @default(now()) @map("created_at")
  status      String   @default("active")
  views       Int      @default(0)
  paidUsd     Float    @default(0.10) @map("paid_usd")
  targetViews Int      @default(0) @map("target_views")
  asset       String   @default("POOL")
  costUsd     Float    @default(0.10) @map("cost_usd")
  costAsset   Float    @default(0) @map("cost_asset")

  user     User      @relation(fields: [userId], references: [id])
  ptpViews PtpView[]

  @@index([userId])
  @@map("ptp_ads")
}

model PtpView {
  id         Int      @id @default(autoincrement())
  adId       Int      @map("ad_id")
  viewerHash String   @map("viewer_hash")
  viewedAt   DateTime @default(now()) @map("viewed_at")

  ad PtpAd @relation(fields: [adId], references: [id])

  @@unique([adId, viewerHash])
  @@map("ptp_views")
}

model PtpEarning {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  adId      Int      @map("ad_id")
  amountUsd Float    @map("amount_usd")
  paidAt    DateTime @default(now()) @map("paid_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("ptp_earnings")
}

model ZeradsCallback {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  username     String
  amountZer    Float    @map("amount_zer")
  exchangeRate Float    @map("exchange_rate")
  payoutAmount Float    @map("payout_amount")
  clicks       Int      @default(0)
  requestIp    String?  @map("request_ip")
  callbackHash String   @unique @map("callback_hash")
  callbackAt   DateTime @map("callback_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("zerads_ptc_callbacks")
}

model AutoMiningReward {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  gpuHashRate Float    @default(1) @map("gpu_hash_rate")
  imageUrl    String?  @map("image_url")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  gpus AutoMiningGpu[]
  logs AutoMiningGpuLog[]

  @@map("auto_mining_rewards")
}

model AutoMiningGpu {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  rewardId    Int       @map("reward_id")
  gpuHashRate Float     @default(1) @map("gpu_hash_rate")
  isAvailable Boolean   @default(true) @map("is_available")
  isClaimed   Boolean   @default(false) @map("is_claimed")
  releasedAt  DateTime  @map("released_at")
  claimedAt   DateTime? @map("claimed_at")
  expiresAt   DateTime? @map("expires_at")

  user   User               @relation(fields: [userId], references: [id])
  reward AutoMiningReward   @relation(fields: [rewardId], references: [id])
  logs   AutoMiningGpuLog[]

  @@index([userId])
  @@index([isClaimed])
  @@map("auto_mining_gpu")
}

model AutoMiningGpuLog {
  id          Int       @id @default(autoincrement())
  userId      Int       @map("user_id")
  gpuId       Int       @map("gpu_id")
  rewardId    Int?      @map("reward_id")
  gpuHashRate Float     @map("gpu_hash_rate")
  action      String
  source      String
  claimedAt   DateTime  @map("claimed_at")
  expiresAt   DateTime? @map("expires_at")
  notes       String?

  user   User              @relation(fields: [userId], references: [id])
  gpu    AutoMiningGpu     @relation(fields: [gpuId], references: [id])
  reward AutoMiningReward? @relation(fields: [rewardId], references: [id])

  @@index([userId])
  @@map("auto_mining_gpu_logs")
}

model CallbackQueue {
  id           Int       @id @default(autoincrement())
  callbackType String    @map("callback_type")
  userId       Int?      @map("user_id")
  username     String?
  amount       Float?
  exchangeRate Float?    @map("exchange_rate")
  payoutAmount Float?    @map("payout_amount")
  data         Json?
  status       String    @default("pending")
  errorMessage String?   @map("error_message")
  retryCount   Int       @default(0) @map("retry_count")
  maxRetries   Int       @default(3) @map("max_retries")
  requestIp    String?   @map("request_ip")
  callbackHash String?   @map("callback_hash")
  createdAt    DateTime  @default(now()) @map("created_at")
  processedAt  DateTime? @map("processed_at")
  nextRetryAt  DateTime? @map("next_retry_at")

  @@index([status])
  @@map("callback_queue")
}

model MiningRewardsLog {
  id                 Int      @id @default(autoincrement())
  userId             Int      @map("user_id")
  blockNumber        Int      @map("block_number")
  workAccumulated    Float    @map("work_accumulated")
  totalNetworkWork   Float    @map("total_network_work")
  sharePercentage    Float    @map("share_percentage")
  rewardAmount       Float    @map("reward_amount")
  balanceAfterReward Float    @map("balance_after_reward")
  createdAt          DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([blockNumber])
  @@map("mining_rewards_log")
}

model DashboardUpdate {
  id          Int       @id @default(autoincrement())
  version     String    @unique
  title       String
  description String
  isActive    Boolean   @default(true) @map("is_active")
  startsAt    DateTime? @map("starts_at")
  endsAt      DateTime? @map("ends_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([isActive])
  @@map("dashboard_updates")
}

model ShortlinkCompletion {
  id            Int       @id @default(autoincrement())
  userId        Int       @unique @map("user_id")
  shortlinkType String    @default("internal") @map("shortlink_type")
  currentStep   Int       @default(0) @map("current_step")
  dailyRuns     Int       @default(0) @map("daily_runs")
  sessionToken  String?   @map("session_token")
  stepStartedAt DateTime? @map("step_started_at")
  completedAt   DateTime? @map("completed_at")
  resetAt       DateTime? @map("reset_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("shortlink_completions")
}

model ShortlinkReward {
  id            Int      @id @default(autoincrement())
  shortlinkType String   @unique @map("shortlink_type")
  minerId       Int      @unique @map("miner_id")
  rewardName    String   @map("reward_name")
  hashRate      Float    @default(0) @map("hash_rate")
  slotSize      Int      @default(1) @map("slot_size")
  imageUrl      String?  @map("image_url")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  miner Miner @relation(fields: [minerId], references: [id])

  @@map("shortlink_rewards")
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  username  String
  message   String
  replyToId Int?     @map("reply_to_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User          @relation(fields: [userId], references: [id])
  replyTo ChatMessage?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies ChatMessage[] @relation("MessageReplies")

  @@index([createdAt])
  @@map("chat_messages")
}

model PrivateMessage {
  id         Int      @id @default(autoincrement())
  senderId   Int      @map("sender_id")
  receiverId Int      @map("receiver_id")
  message    String
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")

  sender   User @relation("SentPrivateMessages", fields: [senderId], references: [id])
  receiver User @relation("ReceivedPrivateMessages", fields: [receiverId], references: [id])

  @@index([senderId, receiverId])
  @@index([createdAt])
  @@map("private_messages")
}

model Referral {
  id         Int      @id @default(autoincrement())
  referrerId Int      @map("referrer_id")
  referredId Int      @unique @map("referred_id")
  createdAt  DateTime @default(now()) @map("created_at")

  referrer User @relation("UserToReferrer", fields: [referrerId], references: [id])
  referred User @relation("UserToReferred", fields: [referredId], references: [id])

  @@map("referrals")
}

model ReferralEarning {
  id         Int      @id @default(autoincrement())
  referrerId Int      @map("referrer_id")
  referredId Int      @map("referred_id")
  amount     Float
  source     String
  createdAt  DateTime @default(now()) @map("created_at")

  referrer User @relation("UserToReferrerEarnings", fields: [referrerId], references: [id])
  referred User @relation("UserToReferredEarnings", fields: [referredId], references: [id])

  @@map("referral_earnings")
}

model BlockDistribution {
  id          Int      @id @default(autoincrement())
  blockNumber Int      @unique @map("block_number")
  reward      Float
  minerCount  Int      @map("miner_count")
  totalWork   Float    @map("total_work")
  createdAt   DateTime @default(now()) @map("created_at")

  minerRewards BlockMinerReward[]

  @@map("block_distributions")
}

model BlockMinerReward {
  id           Int      @id @default(autoincrement())
  blockId      Int      @map("block_id")
  userId       Int      @map("user_id")
  work         Float
  percentage   Float
  rewardAmount Float    @map("reward_amount")
  createdAt    DateTime @default(now()) @map("created_at")

  block BlockDistribution @relation(fields: [blockId], references: [id], onDelete: Cascade)
  user  User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([blockId])
  @@index([userId])
  @@map("block_miner_rewards")
}
