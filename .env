# Admin Users
ADMIN_EMAILS=admin@blockminer.com
ADMIN_EMAIL=admin@blockminer.com
ADMIN_SECURITY_CODE=SecureCode123!
ADMIN_JWT_EXPIRES_IN=24h

# Database
# Override the DATABASE_URL to point to the docker-compose 'db' service if needed, 
# but keep this for local development. Docker-compose.yml will override it if necessary.
DATABASE_URL="postgresql://blockminer:blockminer_password@localhost:5432/blockminer_db?schema=public"
DB_PATH=./data/blockminer.db

# Blockchain (Polygon Mainnet)
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
POLYGON_RPC_TIMEOUT_MS=4500
POLYGON_CHAIN_ID=137

# RECEIVER WALLET (Specific address provided by user)
CHECKIN_RECEIVER=0x1CA03755C5132e238aE4E0f50d4929EA0D58b897
DEPOSIT_WALLET_ADDRESS=0x1CA03755C5132e238aE4E0f50d4929EA0D58b897
