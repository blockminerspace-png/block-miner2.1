# ⚠️ PRODUCTION CONFIG - Nunca commitar .env com dados sensíveis!

# Blockchain
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
POLYGON_RPC_TIMEOUT_MS=4500
POLYGON_CHAIN_ID=137

# Hot Wallet (para saques de cripto)
# Use uma wallet com saldo limitado, nunca a principal!
WITHDRAWAL_PRIVATE_KEY=seu_private_key_aqui
WITHDRAWAL_MNEMONIC=

# Deposits/Check-in (recebedor dos fundos)
CHECKIN_RECEIVER=0x...seu_endereco...
CHECKIN_AMOUNT_WEI=10000000000000000

# JWT (Gerado aleatoriamente, mínimo 32 caracteres)
# Linux: openssl rand -hex 64
JWT_SECRET=sua_chave_secreta_aqui_minimo_32_caracteres
JWT_ISSUER=blockminer
JWT_AUDIENCE=blockminer.app
ACCESS_TOKEN_TTL=12h
REFRESH_TOKEN_TTL_DAYS=30

# App config
ONLINE_START_DATE=2026-02-13
MEMORY_GAME_REWARD_GH=5
NODE_ENV=production
PORT=3000

# Database
DB_PATH=/app/data/blockminer.db

# CORS - Seus dominios
CORS_ORIGINS=https://seu-dominio.com,https://admin.seu-dominio.com

# Opcional: Error tracking (Sentry)
# SENTRY_DSN=

# Opcional: Email (para notificações)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
