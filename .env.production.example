# ⚠️ PRODUCTION CONFIG - Nunca commitar .env com dados sensíveis!

# Blockchain
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
POLYGON_RPC_TIMEOUT_MS=4500
POLYGON_CHAIN_ID=137

# Polygonscan API (verificação de TXs do check-in — mais confiável que RPC puro)
# Gere em https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=sua_api_key_aqui

# Hot Wallet (para saques de cripto)
# Use uma wallet com saldo limitado, nunca a principal!
WITHDRAWAL_PRIVATE_KEY=seu_private_key_aqui
WITHDRAWAL_MNEMONIC=

# CCPayment (depósitos cripto via ITN)
CCPAYMENT_ENABLED=true
CCPAYMENT_APP_ID=seu_app_id
CCPAYMENT_APP_SECRET=seu_app_secret
CCPAYMENT_API_BASE_URL=https://ccpayment.com/ccpayment/v2
CCPAYMENT_CREATE_USER_DEPOSIT_PATH=/createOrGetUserDepositAddress
CCPAYMENT_GET_USER_DEPOSIT_RECORD_PATH=/getUserDepositRecord
CCPAYMENT_TIMEOUT_MS=15000
CCPAYMENT_WEBHOOK_VERIFY_SIGN=true
CCPAYMENT_WEBHOOK_MAX_SKEW_SECONDS=300
CCPAYMENT_CHAIN=POLYGON
CCPAYMENT_ALLOWED_COIN_SYMBOLS=POL,MATIC
# Webhook: https://seu-dominio.com/api/wallet/ccpayment/deposit-webhook

# Deposits/Check-in (recebedor dos fundos)
CHECKIN_RECEIVER=0x...seu_endereco...
CHECKIN_AMOUNT_WEI=10000000000000000

# JWT (Gerado aleatoriamente, mínimo 32 caracteres)
# Linux: openssl rand -hex 64
JWT_SECRET=sua_chave_secreta_aqui_minimo_32_caracteres
JWT_ISSUER=blockminer
JWT_AUDIENCE=blockminer.app
ACCESS_TOKEN_TTL=12h
REFRESH_TOKEN_TTL_DAYS=30

# App config
ONLINE_START_DATE=2026-02-13
MEMORY_GAME_REWARD_GH=5
NODE_ENV=production
PORT=3000

# Database
DB_PATH=/app/data/blockminer.db

# Backup (diário local + replicação externa opcional)
BACKUP_ENABLED=true
BACKUP_CRON=0 3 * * *
BACKUP_RUN_ON_STARTUP=true
BACKUP_STARTUP_DELAY_MS=60000
BACKUP_DIR=/app/backups
BACKUP_RETENTION_DAYS=7
BACKUP_FILENAME_PREFIX=blockminer-db-

# Externo (NAS/disco secundário)
BACKUP_EXTERNAL_ENABLED=true
BACKUP_EXTERNAL_DIR=/mnt/external-backups/blockminer
BACKUP_EXTERNAL_RETENTION_DAYS=30

# Google Drive (via rclone)
# Exige: rclone instalado e remoto "gdrive" configurado no servidor
BACKUP_CLOUD_ENABLED=true
BACKUP_CLOUD_COMMAND=rclone copy "{backupFile}" "gdrive:blockminer-backups" --transfers 1 --checkers 1 --drive-chunk-size 32M --fast-list
BACKUP_CLOUD_TIMEOUT_MS=120000

# Backup completo do site ao iniciar (DB + código fonte)
BACKUP_FULL_SITE_ON_STARTUP=true
BACKUP_FULL_SITE_STARTUP_DELAY_MS=15000

# CORS - Seus dominios
CORS_ORIGINS=https://seu-dominio.com,https://admin.seu-dominio.com

# Opcional: Error tracking (Sentry)
# SENTRY_DSN=

# Opcional: Email (para notificações)
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=

# ZerAds
ZERADS_SITE_ID=10776
ZERADS_CALLBACK_PASSWORD=password
# Leave empty to disable IP restriction
ZERADS_ALLOWED_IPS=
ZERADS_PTC_EXCHANGE_RATE=0
ZERADS_REWARD_NAME=
ZERADS_OFFERWALL_URL_TEMPLATE=https://zerads.com/?ref={siteId}&user={username}
